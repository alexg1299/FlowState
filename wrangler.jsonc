{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowstate",
  "pages_build_output_dir": "dist/coffee-app/browser",
  "compatibility_date": "2026-05-07",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
